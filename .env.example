# Browser
NEXT_PUBLIC_SOCKET_URL=http://localhost:3001

# Realtime API
PORT=3001
CORS_ORIGINS=http://localhost:3000
ROOM_CLEANUP_MS=1800000
MAX_CODE_BYTES=65536
MAX_REPLAY_FRAMES=1200
MAX_SUBMISSIONS_PER_ROOM=500
EXECUTION_CONCURRENCY=2
EXECUTION_OUTPUT_LIMIT_BYTES=65536

# Pin these to immutable image digests in production.
EXECUTOR_PYTHON_IMAGE=python:3.11-alpine
EXECUTOR_JAVASCRIPT_IMAGE=node:22-alpine
EXECUTOR_CPP_IMAGE=gcc:14.2
EXECUTOR_JAVA_IMAGE=eclipse-temurin:21-jdk-alpine
